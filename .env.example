# Supabase 프로젝트 설정 (https://supabase.com/dashboard → 프로젝트 → Settings → API)

# 클라이언트/서버 공용 (브라우저 노출 OK)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 서버 전용 — 계정 시드 스크립트에서만 사용. 절대 클라이언트/깃에 노출 금지!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 로그인 ID → 이메일 매핑 도메인 (가짜 도메인이어도 됨)
NEXT_PUBLIC_LOGIN_EMAIL_DOMAIN=poongsan.app

# 배포 도메인 — 카카오톡/SNS 공유 미리보기(OG) 절대 URL 생성에 사용.
# 미설정 시 Vercel URL로 자동 폴백되지만, 카톡 캐시 안정성을 위해 운영 도메인 명시 권장.
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# 웹 푸시 알림(VAPID) — 생성: npx web-push generate-vapid-keys
# 공개키는 브라우저 노출 OK, 비밀키는 서버 전용(절대 노출 금지)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com
